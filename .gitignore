# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# Environments
.venv/
venv/
env/
.env
.env.local

# Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — track structure only, not contents
data/raw/*
data/processed/*
data/external/*
!data/**/.gitkeep

# Outputs — the generated report (Markdown + CSVs) and figures ARE the
# deliverable, so they are tracked. Only large model binaries and scratch
# scenario dirs are ignored.
outputs/models/*
!outputs/models/.gitkeep
outputs/scenario_*/
!outputs/**/.gitkeep

# Secrets / local overrides
config.local.yaml
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
