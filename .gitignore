# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# Environments
.venv/
venv/
env/
.env
.env.local

# Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — track structure only, not contents
data/raw/*
data/processed/*
data/external/*
# scanner snapshot DBs grow over time; keep the dir, not its contents
data/kalshi/*
!data/**/.gitkeep

# Outputs — the generated report (Markdown + CSVs) and figures ARE the
# deliverable, so they are tracked. Only large model binaries and scratch
# scenario dirs are ignored.
outputs/models/*
!outputs/models/.gitkeep
outputs/scenario_*/
!outputs/**/.gitkeep

# Secrets / local overrides
config.local.yaml
kalshi_scanner.local.yaml
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Generated at runtime (machine-specific paths / timestamps)
outputs/index.html
outputs/kalshi_dashboard.html
